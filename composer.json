{
  "name": "toxo/toxo-cloud-laravel",
  "description": "Laravel client package for TOXO Cloud (.toxo layers)",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Mohit Anand",
      "email": "admin@veoksha.com"
    },
    {
      "name": "Mohit Anand",
      "email": "mohitanand540@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Toxo\\Cloud\\Laravel\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Toxo\\Cloud\\Laravel\\ToxoCloudServiceProvider"
      ]
    }
  },
  "require": {
    "php": ">=8.1",
    "psr/http-client": "^1.0",
    "psr/http-message": "^2.0",
    "psr/http-factory": "^1.0",
    "guzzlehttp/psr7": "^2.0"
  },
  "suggest": {
    "guzzlehttp/guzzle": "Recommended PSR-18 HTTP client implementation.",
    "symfony/yaml": "Required only if you want to pass YAML files to agentRun()."
  }
}

